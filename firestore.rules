rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidString(request.resource.data.name, 2, 100)
        && isValidString(request.resource.data.email, 5, 100);
      allow update: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
      allow delete: if isOwner(userId);
    }
    
    // Public helper profiles (name only) for nearby search
    match /helpers/{helperId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(helperId);
    }
    
    // Emergency requests collection (coleção real usada pelo app)
    match /emergency_requests/{emergencyId} {
      // list: qualquer usuário autenticado pode fazer queries (necessário para observeNearbyEmergencies)
      allow list: if isAuthenticated();
      // get: apenas participantes podem ler documento individual, ou helper para transação de accept
      allow get: if isAuthenticated()
        && (request.auth.uid == resource.data.requesterId
            || request.auth.uid == resource.data.helperId
            // Helper pode ler qualquer emergência ativa para transação atômica de accept
            || resource.data.active == true);
      allow create: if isAuthenticated()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number
        && request.resource.data.active == true;
      allow update: if isAuthenticated()
        && (
          // Requester ou helper já atribuído podem actualizar livremente
          request.auth.uid == resource.data.requesterId
          || request.auth.uid == resource.data.helperId
          // Helper a aceitar: status atual é waiting e ativo
          || (resource.data.status == 'waiting'
              && resource.data.active == true
              && request.resource.data.helperId == request.auth.uid
              && request.resource.data.status == 'matched')
        );
      allow delete: if false;
    }
    
    // Professionals collection (legacy)
    match /professionals/{professionalId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(professionalId)
        && isValidString(request.resource.data.name, 2, 100)
        && isValidString(request.resource.data.specialty, 2, 50)
        && request.resource.data.subscriptionStatus in ['active', 'inactive', 'trial'];
      allow update: if isOwner(professionalId);
      allow delete: if isOwner(professionalId);
    }

    // Health professionals collection (usado pelo app KMM)
    match /health_professionals/{professionalId} {
      allow read: if isAuthenticated();
      // Writes apenas via Cloud Functions (Stripe webhook) ou pelo próprio profissional
      allow create, update: if isAuthenticated() && isOwner(professionalId);
      allow delete: if false;
    }
    
    // UBS (Health Centers) - read-only for users
    match /ubs/{ubsId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin can write via Functions
    }
    
    // Educational content
    match /education/{contentId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin can write
    }
    
    // User ratings
    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    // Chat messages for emergencies (used by ChatRepositoryImpl via emergency_chats collection)
    match /emergency_chats/{emergencyId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid
        && isValidString(request.resource.data.message, 1, 1000);
      allow update, delete: if false;
    }

    // Leads collection (website interest forms)
    match /leads/{leadId} {
      allow create: if isAuthenticated()
        && isValidString(request.resource.data.name, 2, 200)
        && isValidString(request.resource.data.email, 5, 100)
        && isValidString(request.resource.data.plan, 1, 200)
        && request.resource.data.type in ['medico', 'clinica'];
      allow read, update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
