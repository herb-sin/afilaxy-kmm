rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidString(request.resource.data.name, 2, 100)
        && isValidString(request.resource.data.email, 5, 100);
      allow update: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
      allow delete: if isOwner(userId);
    }
    
    // Public helper profiles (name only) for nearby search
    match /helpers/{helperId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(helperId);
    }
    
    // Emergency requests collection (coleção real usada pelo app)
    match /emergency_requests/{emergencyId} {
      // list: necessário para observeNearbyEmergencies (helpers buscando emergências próximas)
      // e para getActiveEmergency / getUserEmergencyHistory do próprio usuário.
      // Restrição de dados sensíveis (nome, coordenadas de outros pacientes) é feita
      // via Firestore Security Rules no nível de document (get) abaixo.
      allow list: if isAuthenticated();
      // get: apenas participantes podem ler documento individual, ou helper para transação de accept
      allow get: if isAuthenticated()
        && (request.auth.uid == resource.data.requesterId
            || request.auth.uid == resource.data.helperId
            // Helper pode ler qualquer emergência ativa para transação atômica de accept
            || resource.data.active == true);
      allow create: if isAuthenticated()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number
        && request.resource.data.active == true;
      allow update: if isAuthenticated()
        && (
          // Requester ou helper já atribuído podem actualizar livremente
          request.auth.uid == resource.data.requesterId
          || request.auth.uid == resource.data.helperId
          // Helper a aceitar: status atual é waiting e ativo.
          // Restringe os campos permitidos para evitar que o helper altere
          // dados do requester (nome, coordenadas) na mesma operação.
          || (resource.data.status == 'waiting'
              && resource.data.active == true
              && request.resource.data.helperId == request.auth.uid
              && request.resource.data.status == 'matched'
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['helperId', 'helperName', 'status', 'matchedAt', 'expiresAt']))
        );
      allow delete: if false;
    }
    
    // Professionals collection (legacy)
    match /professionals/{professionalId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(professionalId)
        && isValidString(request.resource.data.name, 2, 100)
        && isValidString(request.resource.data.specialty, 2, 50)
        && request.resource.data.subscriptionStatus in ['active', 'inactive', 'trial'];
      allow update: if isOwner(professionalId);
      allow delete: if isOwner(professionalId);
    }

    // Health professionals collection (usado pelo app KMM)
    match /health_professionals/{professionalId} {
      allow read: if isAuthenticated();
      // Writes apenas via Cloud Functions (Stripe webhook) ou pelo próprio profissional
      allow create, update: if isAuthenticated() && isOwner(professionalId);
      allow delete: if false;
    }
    
    // UBS (Health Centers) - read-only for users
    match /ubs/{ubsId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin can write via Functions
    }
    
    // Educational content
    match /education/{contentId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin can write
    }
    
    // User ratings
    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    // Chat messages for emergencies (used by ChatRepositoryImpl via emergency_chats collection)
    match /emergency_chats/{emergencyId}/messages/{messageId} {
      // Apenas os participantes da emergência podem ler as mensagens
      allow read: if isAuthenticated()
        && (request.auth.uid == get(/databases/$(database)/documents/emergency_requests/$(emergencyId)).data.requesterId
            || request.auth.uid == get(/databases/$(database)/documents/emergency_requests/$(emergencyId)).data.helperId);
      // Sender must be authenticated AND the actual author AND a participant.
      // The "system" senderId bypass was removed: system messages must be written
      // via Admin SDK (Cloud Functions) which bypasses rules entirely.
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid
        && (request.auth.uid == get(/databases/$(database)/documents/emergency_requests/$(emergencyId)).data.requesterId
            || request.auth.uid == get(/databases/$(database)/documents/emergency_requests/$(emergencyId)).data.helperId)
        && isValidString(request.resource.data.message, 1, 1000);
      allow update, delete: if false;
    }

    // Leads collection (website interest forms)
    match /leads/{leadId} {
      allow create: if isAuthenticated()
        && isValidString(request.resource.data.name, 2, 200)
        && isValidString(request.resource.data.email, 5, 100)
        && isValidString(request.resource.data.plan, 1, 200)
        && request.resource.data.type in ['medico', 'clinica'];
      allow read, update, delete: if false;
    }

    // Check-ins da Agenda de Saúde — cada usuário lê/escreve apenas os seus
    match /checkins/{userId}/responses/{responseId} {
      allow read, write: if isOwner(userId);
    }

    // Perfil médico — dados clínicos sensíveis, apenas o próprio usuário
    match /medical_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Medicações — vinculadas ao userId no documento
    match /medications/{medicationId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // Contatos de emergência médica
    match /emergency_contacts/{contactId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // Exames médicos
    match /medical_exams/{examId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // Notificações — escritas pelo app client (idealmente migrar para Cloud Function)
    match /notifications/{notificationId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'type', 'timestamp'])
        && request.resource.data.type is string
        && request.resource.data.timestamp is number;
      allow read, update, delete: if false;
    }

    // NPS responses
    match /nps_responses/{responseId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Reviews de emergência
    match /reviews/{reviewId} {
      allow create: if isAuthenticated()
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow read: if isAuthenticated()
        && (resource.data.reviewerId == request.auth.uid
            || resource.data.reviewedId == request.auth.uid);
      allow update, delete: if false;
    }

    // User statistics — written exclusively by Cloud Functions (Admin SDK).
    // Client only reads its own document to display weekly emergency count.
    match /user_stats/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions (Admin SDK) can write
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
