<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Método de distribuição: ad-hoc | app-store | development -->
    <!-- Alterado automaticamente pelo workflow iOS no GitHub Actions -->
    <key>method</key>
    <string>app-store-connect</string>

    <!-- Team ID — injetado pelo workflow via PlistBuddy usando secret APPLE_TEAM_ID -->
    <key>teamID</key>
    <string>REPLACE_BY_CI</string>

    <!-- Gerenciamento de signing -->
    <key>signingStyle</key>
    <string>automatic</string>

    <!-- Compila para dispositivos reais (não simulador) -->
    <key>destination</key>
    <string>export</string>

    <!-- Comprime símbolos de debug no IPA -->
    <key>stripSwiftSymbols</key>
    <true/>

    <!-- Thinning: none = universal, <device-model> = específico -->
    <key>thinning</key>
    <string>&lt;none&gt;</string>

    <!-- Inclui símbolos para crash reporting -->
    <key>uploadSymbols</key>
    <true/>

    <!-- Xcode 16+: faz upload ao App Store Connect / TestFlight durante o export.
         Substitui xcrun altool --upload-app (removido no Xcode 16).
         Só tem efeito quando method=app-store-connect. -->
    <key>uploadAndDistribute</key>
    <true/>
</dict>
</plist>
