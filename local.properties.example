# Local configuration file (DO NOT COMMIT)
# Copy this file to local.properties and add your keys

# Google Maps API Key
# Get it from: https://console.cloud.google.com/google/maps-apis
MAPS_API_KEY=YOUR_MAPS_API_KEY_HERE

# Release Signing (after running ./create-keystore.sh)
KEYSTORE_FILE=release.keystore
KEYSTORE_PASSWORD=your_keystore_password
KEY_ALIAS=afilaxy
KEY_PASSWORD=your_key_password

# SDK paths (auto-generated by Android Studio)
sdk.dir=/home/afilaxy/Android/Sdk
